# Database
POSTGRES_USER=ebook
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=ebook_factory
DATABASE_URL=postgresql+asyncpg://ebook:CHANGE_ME_STRONG_PASSWORD@postgres:5432/ebook_factory
SYNC_DATABASE_URL=postgresql://ebook:CHANGE_ME_STRONG_PASSWORD@postgres:5432/ebook_factory

# Redis
REDIS_URL=redis://redis:6379/0

# Storage (MinIO)
MINIO_ROOT_USER=ebook
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_SECRET
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=ebook
STORAGE_SECRET_KEY=CHANGE_ME_MINIO_SECRET
STORAGE_BUCKET=ebook-factory

# Langfuse
LANGFUSE_PUBLIC_KEY=lf_pk_placeholder
LANGFUSE_SECRET_KEY=lf_sk_placeholder
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_SECRET=change-me-langfuse-nextauth-secret
LANGFUSE_SALT=change-me-langfuse-salt

# LLM (OpenAI-compatible)
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# App
APP_ENV=production
LOG_LEVEL=INFO
